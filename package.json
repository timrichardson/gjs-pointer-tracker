{
  "name": "gjs-pointer-tracker",
  "license": "GPL-3.0-or-later",
  "author": "Johannes Garz <johannes@garz.dev> (https://garz.dev/)",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf pointer-tracker@garz.dev && tsc && cp -r metadata.json schemas pointer-tracker@garz.dev",
    "zip": "yarn build && cd pointer-tracker@garz.dev && zip -rFS ../pointer-tracker@garz.dev.zip .",
    "disable": "rm -rf ~/.local/share/gnome-shell/extensions/pointer-tracker@garz.dev",
    "enable": "yarn disable && yarn build && cp -r pointer-tracker@garz.dev ~/.local/share/gnome-shell/extensions/ && glib-compile-schemas ~/.local/share/gnome-shell/extensions/pointer-tracker@garz.dev/schemas",
    "test": "yarn enable && env G_MESSAGES_DEBUG='GNOME Shell' dbus-run-session -- gnome-shell --devkit",
    "ncu": "ncu -u",
    "lint": "prettier --check . && eslint -c eslint-cli.config.js --max-warnings 0",
    "format": "prettier -w . && eslint -c eslint-cli.config.js --fix"
  },
  "sideEffects": "false",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "npm-check-updates": "^19.1.2",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@girs/gjs": "^4.0.0-beta.38",
    "@girs/gnome-shell": "^49.1.0"
  }
}
